generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String
  todos     Todo[]
}

model Todo {
  id        Int       @id @default(autoincrement())
  task      String
  completed Boolean   @default(false)
  user_id    Int   
  user      User      @relation(fields: [user_id], references: [id])
}